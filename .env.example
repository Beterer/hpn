# Copy to .env (git-ignored) for local overrides. Compose ships working dev
# defaults, so this is only needed when you want to change them. No real secrets
# belong in the repo (backbone §10.9) — production values are env-injected.

# Postgres (matches docker-compose + appsettings.Development.json)
POSTGRES_USER=hpn
POSTGRES_PASSWORD=hpn
POSTGRES_DB=hpn

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=hpn
MINIO_ROOT_PASSWORD=hpn-secret

# Optional: OTLP traces/metrics exporter endpoint (unset = no export)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
